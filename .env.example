# ============================================
# AnythingLLM 配置
# ============================================
# AnythingLLM 的开发商的API Key
# ###############这一项必须填写################
# ANYTHINGLLM_API_KEY=WF2P6W5-1DK41R7-JF10A8H-F381F8P
# AnythingLLM 默认连接配置
ANYTHINGLLM_BASE_URL=http://localhost:3001/api/v1
# 请求超时（秒）（可选）
ANYTHINGLLM_TIMEOUT=
# AnythingLLM storage 根目录（可选）
ANYTHINGLLM_STORAGE_ROOT=

# ============================================
# Web UI 配置
# ============================================
# 应用的监听地址和端口
WEB_UI_HOST=127.0.0.1
WEB_UI_PORT=5001
WEB_UI_DEBUG=true

# ============================================
# 文件存储配置
# ============================================
# 分类成功后文件在本地的存放目录
DOCSENSE_FILE_STORE_DIR=uploads
# 文件上传的暂存目录（请求处理期间使用）
DOCSENSE_TEMP_UPLOAD_DIR=.runtime/inbox
# 正式 `/llm/*` 任务 SQLite 路径
DOCSENSE_LLM_TASK_DB=.runtime/llm_tasks.sqlite3
# 单次请求容量限制，单位：字节，默认 500MB
DOCSENSE_MAX_CONTENT_LENGTH=524288000

# ============================================
# LLM 集成配置
# ============================================
# 甲方业务系统回调地址，本次测试时与 Mock Callback Server 保持一致
# ###############这一项必须填写################
# DOCSENSE_LLM_CALLBACK_URL=http://127.0.0.1:9000/llm/callback
# 回调超时秒数，默认10秒
DOCSENSE_LLM_CALLBACK_TIMEOUT=10
# 文件下载超时秒数，默认60秒
DOCSENSE_LLM_DOWNLOAD_TIMEOUT=60
# 甲方文件下载暂存目录，默认 `.runtime/llm_downloads`
DOCSENSE_LLM_DOWNLOAD_DIR=.runtime/llm_downloads

# ============================================
# OCR 配置
# ============================================
# 处理扫描版 PDF 时，是否自动进行 OCR 识别转换为 Markdown
DOCSENSE_OCR_ENABLED=true
# OCR 识别的语言，默认中文和英文
DOCSENSE_OCR_LANGUAGES=chi_sim+eng
# OCR 识别的DPI，默认300
DOCSENSE_OCR_DPI=300
# OCR 识别的抽样页数，默认3页
DOCSENSE_OCR_SAMPLE_PAGES=3
# OCR 识别的文本阈值，默认50
DOCSENSE_OCR_TEXT_THRESHOLD=50
# OCR 识别的缓存目录，默认 `.runtime/ocr_markdown`
DOCSENSE_OCR_CACHE_DIR=.runtime/ocr_markdown
# Tesseract 语言包目录（如果 Tesseract 未正确安装或找不到语言包时需要手动指定）
TESSDATA_PREFIX=

# ============================================
# Mock Callback Server 配置
# ============================================
# 模拟甲方回调接口的监听地址和端口
MOCK_CALLBACK_HOST=127.0.0.1
MOCK_CALLBACK_PORT=9000